# Local credentials for econ-judge deploy + smoke tests.
# Copy this file to `.env` (which is gitignored), fill in the values, and the
# test scripts will pick them up automatically.

# Deploy URL (Render auto-assigns; if you used a custom domain, put that here)
ECON_JUDGE_URL=https://econ-judge.onrender.com

# CTFd admin user. The password lives ONLY in Render's Environment
# (CTFD_ADMIN_PASSWORD, generated by Render). Do NOT paste the real value here
# — this file is committed to git. For local test scripts, put the real value
# in your gitignored .env instead.
CTFD_ADMIN_NAME=admin
CTFD_ADMIN_PASSWORD=

# Hidden smoke-test user pre-created by bin/bootstrap.py. These values must
# match the SMOKE_NAME / SMOKE_PASSWORD constants in bootstrap.py and the
# defaults in tests/deploy_smoke.py — change in all three places together.
SMOKE_USER=smoke-test-1
SMOKE_PASSWORD=smoketest-pw-1
